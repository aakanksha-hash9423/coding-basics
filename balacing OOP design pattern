import threading
from abc import ABC, abstractmethod

# --- 1. CREATIONAL: Singleton (Thread-Safe) ---
# Ensures a single instance
class Singleton:
    _instance = None
    _lock = threading.Lock()
    def __new__(cls):
        with cls._lock:
            if cls._instance is None:
                cls._instance = super(Singleton, cls).__new__(cls)
        return cls._instance

# --- 2. CREATIONAL: Factory Method ---
# Creates objects without specifying the exact class
class Notification(ABC):
    @abstractmethod
    def send(self, message): pass
class Email(Notification):
    def send(self, message): print(f"Email: {message}")
def notification_factory(type="email"):
    return Email() if type == "email" else None

# --- 3. STRUCTURAL: Decorator ---
# Dynamically adds behavior to objects
def debug_decorator(func):
    def wrapper():
        print("Logging...")
        func()
    return wrapper

@debug_decorator
def core_logic():
    print("Action.")

# --- 4. BEHAVIORAL: Strategy ---
# Encapsulates algorithms
class Strategy(ABC):
    @abstractmethod
    def pay(self, amount): pass
class CreditCard(Strategy):
    def pay(self, amount): print(f"Paid ${amount}")

# --- Execution ---
if __name__ == "__main__":
    # Test instances
    s1, s2 = Singleton(), Singleton()
    print(f"Singleton works: {s1 is s2}")
    
    core_logic()
    
    payment = CreditCard()
    payment.pay(100)
