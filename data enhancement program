import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler, LabelEncoder

def enhance_data(file_path):
    # 1. Load Data
    # Use convert_dtypes() for optimized memory usage
    df = pd.read_csv(file_path).convert_dtypes() 
    
    # 2. Basic Cleaning: Remove Duplicates
    df = df.drop_duplicates()
    
    # 3. Missing Value Handling
    # Fill numerical columns with median and categorical with mode
    for col in df.columns:
        if df[col].dtype in ['float64', 'int64', 'Int64']:
            df[col] = df[col].fillna(df[col].median())
        else:
            df[col] = df[col].fillna(df[col].mode()[0])
            
    # 4. Feature Engineering (Enhancement)
    # Example: Create a 'High-Value' flag based on a price threshold
    if 'price' in df.columns:
        df['is_high_value'] = (df['price'] > df['price'].mean()).astype(int)
        
    # 5. Data Transformation: Normalization
    # Scaling numerical features for machine learning readiness
    scaler = StandardScaler()
    num_cols = df.select_dtypes(include=[np.number]).columns
    df[num_cols] = scaler.fit_transform(df[num_cols])
    
    # 6. Categorical Encoding
    # Convert text categories into numerical format
    le = LabelEncoder()
    cat_cols = df.select_dtypes(include=['object', 'string']).columns
    for col in cat_cols:
        df[col] = le.fit_transform(df[col].astype(str))
        
    return df

