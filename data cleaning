import pandas as pd
import numpy as np

def clean_dataset(df):
    """
    A comprehensive data cleaning function covering common preprocessing steps.
    """
    # 1. Standardize Column Names
    # Remove whitespace, lowercase, and replace spaces with underscores
    df.columns = df.columns.str.strip().str.lower().str.replace(' ', '_')

    # 2. Handle Duplicates
    # Keep the first occurrence and remove the rest
    df = df.drop_duplicates().reset_index(drop=True)

    # 3. Handle Missing Values
    # Identify numerical and categorical columns for specific treatments
    num_cols = df.select_dtypes(include=[np.number]).columns
    cat_cols = df.select_dtypes(include=['object', 'category']).columns

    # Fill numerical missing values with the median and categorical with 'Unknown'
    df[num_cols] = df[num_cols].fillna(df[num_cols].median())
    df[cat_cols] = df[cat_cols].fillna('Unknown')

    # 4. Standardize Text Data
    # Strip whitespace and capitalize categorical strings consistently
    for col in cat_cols:
        df[col] = df[col].astype(str).str.strip().str.title()

    # 5. Data Type Conversion
    # Convert 'date' column to datetime objects if it exists
    if 'date' in df.columns:
        df['date'] = pd.to_datetime(df['date'], errors='coerce')

    # Coerce numeric columns to ensure proper float/int types
    for col in num_cols:
        df[col] = pd.to_numeric(df[col], errors='coerce')

    # 6. Handle Outliers (Capping)
    # Clip values at 1st and 99th percentiles to minimize impact of extremes
    for col in num_cols:
        lower_limit = df[col].quantile(0.01)
        upper_limit = df[col].quantile(0.99)
        df[col] = df[col].clip(lower_limit, upper_limit)

    return df

